# Gemini LLM Configuration (Vertex AI - recommended for GCP)
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_MODE=vertex
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=global
CUSTOM_LLM_BASE_URL=https://custom-llm-gc-221330051580.us-central1.run.app

# Gemini LLM Configuration (Public API - for local testing)
# GEMINI_API_MODE=public
# GOOGLE_API_KEY=your-api-key-here

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXP_HOURS=12

# Tavus Pre-warming Configuration (optional but recommended)
TAVUS_CUSTOM_LLM_ENABLE=true

# Frontend Configuration (build-time)
VITE_TAVUS_BACKEND_URL=http://localhost:8086
VITE_VAPI_PUBLIC_KEY=pk_your_vapi_public_key_here

# Production Notes:
# - For Azure, set CORS_ORIGINS to your frontend FQDN (no trailing slash)
#   Example: https://your-frontend.azurecontainerapps.io
# - For Azure, set VITE_TAVUS_BACKEND_URL to your backend FQDN
#   Example: https://your-backend.azurecontainerapps.io
# - For production, set TAVUS_CALLBACK_URL to a public webhook endpoint
# - Add your frontend origin to Tavus allowed origins in Tavus dashboard
# - Set VITE_VAPI_PUBLIC_KEY to your Vapi.ai public key (starts with pk_)

