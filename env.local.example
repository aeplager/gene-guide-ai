# Local Docker environment file template
# Copy to .env.local and update values as needed.

# Backend Configuration
TAVUS_API_KEY=your_tavus_api_key_here
TAVUS_REPLICA_ID=r4317e64d25a
TAVUS_PERSONA_ID=p92464cdb59e
TAVUS_CALLBACK_URL=
CORS_ORIGINS=http://localhost:8090

# Tavus Recording Configuration (optional)
TAVUS_ENABLE_RECORDING=false
TAVUS_RECORDING_S3_BUCKET_NAME=your-s3-bucket-name
TAVUS_RECORDING_S3_BUCKET_REGION=us-east-1
TAVUS_AWS_ASSUME_ROLE_ARN=arn:aws:iam::123456789012:role/your-role-name

# Database Configuration
DB_CONNECTION_STRING=postgresql://postgres:change-me@localhost:5432/agentic_core
COMPANY_ID=1

# Gemini LLM Configuration (Public API for local testing)
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_MODE=public
GOOGLE_API_KEY=your-google-api-key
CUSTOM_LLM_BASE_URL=http://localhost:8086

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXP_HOURS=12

# Tavus Pre-warming Configuration
TAVUS_CUSTOM_LLM_ENABLE=true

# Frontend Configuration (build-time)
VITE_TAVUS_BACKEND_URL=http://localhost:8086
VITE_VAPI_PUBLIC_KEY=pk_your_vapi_public_key_here
